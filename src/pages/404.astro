---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 · Not found" description="This page could not be found.">
  <section class="container" style="min-height:60vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;gap:18px;">
    <span class="eyebrow">error 404</span>
    <h1 style="font-size:clamp(2.4rem,8vw,4rem);color:var(--text-strong);letter-spacing:-0.03em;">Page not found</h1>
    <p style="color:var(--muted);max-width:46ch;">The page you're looking for doesn't exist or has moved.</p>
    <div class="hero-actions" style="justify-content:center;">
      <a class="btn btn-primary" href="/">Back home</a>
      <a class="btn" href="/blog">Read the blog →</a>
    </div>
  </section>
</BaseLayout>
