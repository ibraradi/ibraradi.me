---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SOCIALS, EXPERIENCE, SKILLS, AWARDS, EDUCATION, CERTIFICATES, VOLUNTEERING } from '../consts';

// Severity ranking for findings (most impactful first).
const SEV = ['crit', 'high', 'info', 'info'];
const findings = EXPERIENCE.map((xp, i) => ({ ...xp, sev: SEV[i] ?? 'info', n: i + 1 }));

const ghShort = SOCIALS.github.replace('https://', '');
const liShort = SOCIALS.linkedin.replace('https://www.', '').replace(/\/$/, '');
---

<BaseLayout>
  <div class="doc">
    <!-- TITLE BLOCK -->
    <section class="doc-hero" data-reveal>
      <div>
        <p class="dh-kicker">Dossier <b>001</b> · Subject Profile · Classification: <b>Open Source</b></p>
        <h1 class="dh-name"><span class="grad" data-scramble>Ibrahim Radi</span></h1>
        <p class="dh-alias">aka @ibraradi · "the technical co-founder"</p>
        <p class="dh-assess">
          Subject is a security engineer operating on both sides of the line — building attack-surface-management,
          threat-intel and brand-protection platforms, and conducting offensive operations as a pentester, bug bounty
          hunter and CTF competitor. Assessed capability: <span class="c-strong">high</span>.
        </p>
      </div>
      <div class="photo" aria-label="Subject photo on file">
        <span class="xhair tl"></span><span class="xhair tr"></span>
        <span class="xhair bl"></span><span class="xhair br"></span>
        IR
      </div>
    </section>

    <!-- IDENTIFIERS -->
    <section class="dsec" data-reveal>
      <div class="dsec-head">
        <span class="dsec-no">§01</span><span class="dsec-title">Identifiers</span>
        <span class="dsec-meta">verified</span>
      </div>
      <div class="fields">
        <div class="field"><div class="field-k">Full name</div><div class="field-v">Ibrahim Radi</div></div>
        <div class="field"><div class="field-k">Handle</div><div class="field-v mono">@ibraradi</div></div>
        <div class="field"><div class="field-k">Last known location</div><div class="field-v">{SITE.location}</div></div>
        <div class="field"><div class="field-k">Current role</div><div class="field-v">Co-Founder @ Flawtrack</div></div>
        <div class="field"><div class="field-k">Direct line</div><div class="field-v mono"><span class="redacted" tabindex="0">+•• ••• ••• ••••</span></div></div>
        <div class="field"><div class="field-k">Clearance</div><div class="field-v mono"><span class="redacted" tabindex="0">AWS-CCP-VERIFIED</span></div></div>
      </div>
    </section>

    <!-- FINDINGS -->
    <section class="dsec" data-reveal>
      <div class="dsec-head">
        <span class="dsec-no">§02</span><span class="dsec-title">Intelligence Findings</span>
        <span class="dsec-meta">{findings.length} logged</span>
      </div>
      <div class="findings">
        {findings.map((f) => (
          <article class={`finding ${f.sev}`} id={`finding-${f.n}`} data-reveal>
            <div class="finding-top">
              <span class="finding-id">FINDING-{String(f.n).padStart(3, '0')}</span>
              <span class={`sev ${f.sev}`}>{f.sev === 'crit' ? 'critical' : f.sev}</span>
              <span class="finding-period">{f.period} · {f.location}</span>
            </div>
            <h3 class="finding-title">{f.role} <span class="c-muted">@</span> <span class="co">{f.company}</span></h3>
            {f.summary && <p class="finding-sum">{f.summary}</p>}
            <ul>
              {f.points.map((p) => <li>{p}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <!-- CAPABILITY MATRIX -->
    <section class="dsec" data-reveal>
      <div class="dsec-head">
        <span class="dsec-no">§03</span><span class="dsec-title">Capability Matrix</span>
        <span class="dsec-meta">{SKILLS.length} domains</span>
      </div>
      <div class="matrix">
        {SKILLS.map((g) => (
          <div class="mx-cell">
            <div class="mx-cat">{g.title}</div>
            <div class="mx-tags">{g.items.map((i) => <span class="mx-tag">{i}</span>)}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- FIELD RECORD -->
    <section class="dsec" data-reveal>
      <div class="dsec-head">
        <span class="dsec-no">§04</span><span class="dsec-title">Field Record</span>
        <span class="dsec-meta">ctf &amp; competitions</span>
      </div>
      <div class="record">
        {AWARDS.map((a) => (
          <div class="rec-row"><span class="rec-mark">★</span><span class="rec-text">{a}</span></div>
        ))}
      </div>
    </section>

    <!-- CREDENTIALS -->
    <section class="dsec" id="credentials" data-reveal>
      <div class="dsec-head">
        <span class="dsec-no">§05</span><span class="dsec-title">Verified Credentials</span>
        <span class="dsec-meta">education · certs · service</span>
      </div>
      <div class="creds">
        {EDUCATION.map((e) => (
          <div class="cred">
            <div class="cred-k">Education</div>
            <div class="cred-main">{e.school}</div>
            <div class="cred-sub">{e.program}</div>
            <div class="cred-sub">{e.period} · {e.note}</div>
          </div>
        ))}
        {CERTIFICATES.map((c) => (
          <div class="cred">
            <div class="cred-k">Certification</div>
            <div class="cred-main">{c.name}</div>
            <div class="cred-sub">{c.issuer}</div>
          </div>
        ))}
        {VOLUNTEERING.map((v) => (
          <div class="cred">
            <div class="cred-k">Service</div>
            <div class="cred-main">{v.role}</div>
            <div class="cred-sub">{v.org}</div>
            <ul>{v.points.map((p) => <li>{p}</li>)}</ul>
          </div>
        ))}
      </div>
    </section>

    <!-- COMMS -->
    <section class="dsec" data-reveal>
      <div class="dsec-head">
        <span class="dsec-no">§06</span><span class="dsec-title">Establish Comms</span>
        <span class="dsec-meta">channels open</span>
      </div>
      <div class="dcomms">
        <a href={`mailto:${SOCIALS.email}`}><span class="dc-k">→ email</span><span class="dc-v">{SOCIALS.email}</span></a>
        <a href={SOCIALS.github} target="_blank" rel="noopener noreferrer"><span class="dc-k">→ github</span><span class="dc-v">{ghShort}</span></a>
        <a href={SOCIALS.linkedin} target="_blank" rel="noopener noreferrer"><span class="dc-k">→ linkedin</span><span class="dc-v">{liShort}</span></a>
      </div>
    </section>
  </div>
</BaseLayout>
