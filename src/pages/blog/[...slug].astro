---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BLOG_ENABLED, SITE } from '../../consts';
import { getPosts, getPost } from '../../lib/storyblok';

export async function getStaticPaths() {
  if (!BLOG_ENABLED) return [];
  const posts = await getPosts();
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
// Pages are pre-rendered from getStaticPaths props; re-fetch as a safety net.
const data = post ?? (await getPost(Astro.params.slug as string));
const html = data?.html ?? '';

const dateFmt = (d: string) =>
  d ? new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
const isoDate = data?.date ? new Date(data.date).toISOString() : undefined;

const articleLd = data && {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  description: data.excerpt,
  datePublished: isoDate,
  image: `${SITE.url}/og.png`,
  keywords: data.tags.join(', '),
  author: { '@type': 'Person', name: SITE.name, url: SITE.url },
  publisher: { '@type': 'Person', name: SITE.name, url: SITE.url },
  mainEntityOfPage: `${SITE.url}/blog/${data.slug}/`,
};
---

<BaseLayout
  title={data?.title}
  description={data?.excerpt}
  path={`/blog/${data?.slug}/`}
  ogType="article"
  image={data ? `/og/${data.slug}.png` : undefined}
  publishedTime={isoDate}
  jsonLd={articleLd || undefined}
>
  <div class="doc post-shell">
    <article class="article post-article">
      <a class="back" href="/blog">← field notes</a>
      <header class="article-header">
        <div class="meta">
          <time datetime={data?.date}>{dateFmt(data?.date ?? '')}</time>
          {data && data.tags.length > 0 && <span> · {data.tags.join(' · ')}</span>}
        </div>
        <h1>{data?.title}</h1>
      </header>
      <div class="article-body" set:html={html}></div>
    </article>

    {data && data.toc.length > 1 && (
      <aside class="toc" aria-label="On this page">
        <div class="toc-inner">
          <div class="toc-head">// on this page</div>
          <nav>
            <ol>
              {data.toc.map((t) => (
                <li><a href={`#${t.id}`}>{t.text}</a></li>
              ))}
            </ol>
          </nav>
        </div>
      </aside>
    )}
  </div>
</BaseLayout>
