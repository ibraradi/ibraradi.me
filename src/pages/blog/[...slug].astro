---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BLOG_ENABLED } from '../../consts';

export async function getStaticPaths() {
  // Blog is feature-flagged off — generate no post pages.
  if (!BLOG_ENABLED) return [];
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={post.data.title} description={post.data.description} path={`/blog/${post.id}/`}>
  <article class="container article">
    <a class="back" href="/blog">← All posts</a>
    <header class="article-header">
      <div class="meta">
        <time datetime={post.data.pubDate.toISOString()}>{dateFmt(post.data.pubDate)}</time>
        {post.data.tags.length > 0 && <span> · {post.data.tags.join(' · ')}</span>}
      </div>
      <h1>{post.data.title}</h1>
      {post.data.updatedDate && (
        <div class="meta">Updated {dateFmt(post.data.updatedDate)}</div>
      )}
    </header>
    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>
