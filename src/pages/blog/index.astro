---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BLOG_ENABLED } from '../../consts';
import { getPosts } from '../../lib/storyblok';

if (!BLOG_ENABLED) {
  return Astro.redirect('/');
}

const posts = await getPosts();
const dateFmt = (d: string) =>
  d ? new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
---

<BaseLayout
  title="Field Notes"
  description="Field write-ups on offensive security, tooling, and research by Ibrahim Radi."
  path="/blog"
>
  <div class="doc">
    <section class="doc-hero" data-reveal>
      <div>
        <p class="dh-kicker">Dossier · <b>Field Notes</b></p>
        <h1 class="dh-name" style="font-size: clamp(2.2rem, 6vw, 3.4rem)">Field Notes</h1>
        <p class="dh-assess">
          Write-ups from the field: offensive security, tooling I had to build, and research worth keeping.
        </p>
      </div>
    </section>

    <section class="dsec" data-reveal>
      <div class="dsec-head">
        <span class="dsec-no">§</span><span class="dsec-title">Transmissions</span>
        <span class="dsec-meta">{posts.length} logged</span>
      </div>

      {posts.length === 0 ? (
        <div class="empty-state">No transmissions published yet. Check back soon.</div>
      ) : (
        <div class="notes">
          {posts.map((p) => (
            <a class="note" href={`/blog/${p.slug}/`}>
              <div class="note-top">
                <time datetime={p.date}>{dateFmt(p.date)}</time>
                {p.tags.length > 0 && <span class="note-tags">{p.tags.join(' · ')}</span>}
              </div>
              <h2 class="note-title">{p.title}</h2>
              {p.excerpt && <p class="note-ex">{p.excerpt}</p>}
              <span class="note-go">read →</span>
            </a>
          ))}
        </div>
      )}
    </section>
  </div>
</BaseLayout>
