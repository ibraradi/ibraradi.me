/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # HTML pages: always revalidate so new deploys / content show immediately.
  Cache-Control: public, max-age=0, must-revalidate

# Fingerprinted build assets are safe to cache forever (override the rule above).
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static assets that keep a stable filename — cache a day, revalidate after.
/og.png
  Cache-Control: public, max-age=86400
/favicon.svg
  Cache-Control: public, max-age=86400
