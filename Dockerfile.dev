# Development image: runs the Astro dev server with hot reload.
# Source is bind-mounted via docker-compose, so it isn't COPYed here.
FROM node:22-alpine

WORKDIR /app

# Install dependencies based on the lockfile. This layer is cached and only
# rebuilds when package.json / package-lock.json change.
COPY package.json package-lock.json* ./
RUN npm install

EXPOSE 4321

# --host makes the server reachable from outside the container.
CMD ["npm", "run", "dev", "--", "--host"]
